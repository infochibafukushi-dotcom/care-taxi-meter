VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=care-taxi-meter.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=care-taxi-meter
VITE_FIREBASE_STORAGE_BUCKET=care-taxi-meter.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

VITE_GOOGLE_MAPS_API_KEY=

# Reservation API base URL (empty = same origin under Vite base, e.g. /care-taxi-meter/api/driver)
# GitHub Pages production: set to the public Cloudflare Worker URL (no trailing slash)
# Example: https://driver-api.example.com
VITE_RESERVATION_API_BASE_URL=

# Local dev only — do NOT use VITE_ prefix (not embedded in client bundle)
# RESERVATION_V4_ORIGIN=https://<reservation-v4-host>
# METER_DRIVER_TOKEN=
#
# Cloudflare Worker (workers/driver-proxy/) — production proxy secrets/vars
# METER_DRIVER_TOKEN=        # wrangler secret (never commit)
# RESERVATION_V4_ORIGIN=     # wrangler var
# ALLOWED_ORIGIN=            # wrangler var (GitHub Pages origin for CORS)
#
# Local direct API check (browser):
#   http://localhost:5173/care-taxi-meter/api/driver/reservations?date=2099-04-22
# Do NOT use http://localhost:5173/api/driver/... (outside Vite base path)
