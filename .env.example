# RESERVATION_V4_ORIGIN=https://<reservation-v4-host>
# METER_DRIVER_TOKEN=
#
# Local direct API check (browser):
#   http://localhost:5173/care-taxi-meter/api/driver/reservations?date=2099-04-22
# Do NOT use http://localhost:5173/api/driver/... (outside Vite base path)
