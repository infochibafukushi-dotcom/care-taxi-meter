rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }
    function role() {
      return signedIn() ? request.auth.token.role : null;
    }
    function franchiseeId() {
      return signedIn()
        ? (request.auth.token.franchiseeId != null
          ? request.auth.token.franchiseeId
          : request.auth.token.companyId)
        : null;
    }
    function isHqAdmin() {
      return role() == 'hq_admin' || role() == 'superAdmin';
    }
    function isFranchiseeOwner() {
      return role() == 'franchisee_owner' || role() == 'owner';
    }
    function isStoreManager() {
      return role() == 'store_manager' || role() == 'manager';
    }
    function sameFranchiseeFromPath(pathFranchiseeId) {
      return franchiseeId() == pathFranchiseeId
        || request.auth.token.companyId == pathFranchiseeId;
    }
    function sameStoreFromPath(pathFranchiseeId, pathStoreId) {
      return sameFranchiseeFromPath(pathFranchiseeId)
        && request.auth.token.storeId == pathStoreId;
    }
    function isAllowedAccountingReceiptContent() {
      return request.resource.size < 10 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
        );
    }

    // 旧パス: .../receipts/{receiptId}/{fileName}
    // 新パス: .../receipts/{receiptId}/original|ocr/{fileName}
    //
    // 注意: このルールで許可される read は Storage オブジェクトへの直接アクセス
    // （getBytes / uploadBytes 後続の確認など）であり、クライアントで長期有効な
    // download token URL（getDownloadURL）を発行・永続化してはならない。
    // 画面表示用の証憑 URL は getAccountingReceiptAccessUrl（Cloud Functions）が発行する
    // 短期署名 URL（v4 signed URL、数分で失効）を経由すること。
    match /accounting/{pathFranchiseeId}/{storeId}/receipts/{receiptId}/{allPaths=**} {
      allow read: if isHqAdmin()
        || (isFranchiseeOwner() && sameFranchiseeFromPath(pathFranchiseeId))
        || (isStoreManager() && sameStoreFromPath(pathFranchiseeId, storeId));
      allow write: if isHqAdmin()
        || ((isFranchiseeOwner() && sameFranchiseeFromPath(pathFranchiseeId)
            || (isStoreManager() && sameStoreFromPath(pathFranchiseeId, storeId)))
          && isAllowedAccountingReceiptContent());
      allow delete: if isHqAdmin()
        || (isFranchiseeOwner() && sameFranchiseeFromPath(pathFranchiseeId))
        || (isStoreManager() && sameStoreFromPath(pathFranchiseeId, storeId));
    }
  }
}
